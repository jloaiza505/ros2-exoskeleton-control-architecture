<launch>
  <arg name="use_sim_time" default="false"/>

  <node pkg="exo_calibration" exec="calibration_node" name="calibration_node" output="screen">
    <param from="$(find-pkg-share exo_system_config)/config/topics.yaml"/>
    <param from="$(find-pkg-share exo_calibration)/config/exo_calibration.yaml"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>
</launch>
